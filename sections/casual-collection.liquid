{{ 'casual-collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sect = section.settings
  assign per_page = sect.products_per_page | default: 9

  comment
    Default: use whatever collection page the customer is on.
    Optional override lets a merchant pin this section to one
    specific collection if it's ever reused outside collection.json.
  endcomment
  assign collection_obj = collection
  if sect.collection_override != blank
    assign collection_obj = collections[sect.collection_override]
  endif
-%}

<div
  class="cc-wrap"
  style="
    --cc-heading-font: {{ sect.heading_font }};
    --cc-heading-weight: {{ sect.heading_weight }};
    --cc-body-font: {{ sect.body_font }};
    --cc-page-title-size: {{ sect.page_title_size }}px;
    --cc-product-title-size: {{ sect.product_title_size }}px;
    --cc-price-size: {{ sect.price_size }}px;
    --cc-body-size: {{ sect.body_size }}px;
    --cc-accent: {{ sect.accent_color }};
  "
  data-cc-root
>

  {%- if sect.show_breadcrumb -%}
  <nav class="cc-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ sect.breadcrumb_home_url | default: '/' }}">{{ sect.breadcrumb_home_text }}</a>
    <span class="cc-breadcrumb-sep">&gt;</span>
    <span class="cc-breadcrumb-current">{{ sect.breadcrumb_current_text | default: collection_obj.title }}</span>
  </nav>
  {%- endif -%}

  <div class="cc-layout">

    <button type="button" class="cc-mobile-filter-toggle" data-cc-mobile-toggle aria-expanded="false" aria-controls="cc-filters-panel">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16M7 12h10M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      {{ sect.filters_heading | default: 'Filters' }}
    </button>

    <aside class="cc-filters" id="cc-filters-panel" data-cc-filters>
      <div class="cc-filters-head">
        <h2 class="cc-filters-title">{{ sect.filters_heading | default: 'Filters' }}</h2>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M6 12h12M10 18h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
      </div>

      {%- comment -%} Product type list {%- endcomment -%}
      <ul class="cc-type-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'type_option' -%}
          <li class="cc-type-item">
            <button type="button" class="cc-type-btn" data-cc-type-filter data-value="{{ block.settings.tag_value }}">
              <span>{{ block.settings.label }}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <hr class="cc-divider">

      {%- comment -%} Price {%- endcomment -%}
      <div class="cc-filter-group">
        <div class="cc-filter-group-head">
          <h3>{{ sect.price_heading | default: 'Price' }}</h3>
        </div>
        <div class="cc-price-slider" data-cc-price-slider
             data-min="{{ sect.price_floor | default: 0 }}"
             data-max="{{ sect.price_ceiling | default: 500 }}"
             data-start-min="{{ sect.price_min_default | default: 50 }}"
             data-start-max="{{ sect.price_max_default | default: 200 }}">
          <div class="cc-price-track">
            <div class="cc-price-range" data-cc-price-range></div>
          </div>
          <input type="range" class="cc-price-input cc-price-input-min" data-cc-price-min
                 min="{{ sect.price_floor | default: 0 }}" max="{{ sect.price_ceiling | default: 500 }}"
                 value="{{ sect.price_min_default | default: 50 }}">
          <input type="range" class="cc-price-input cc-price-input-max" data-cc-price-max
                 min="{{ sect.price_floor | default: 0 }}" max="{{ sect.price_ceiling | default: 500 }}"
                 value="{{ sect.price_max_default | default: 200 }}">
          <div class="cc-price-labels">
            <span data-cc-price-min-label>${{ sect.price_min_default | default: 50 }}</span>
            <span data-cc-price-max-label>${{ sect.price_max_default | default: 200 }}</span>
          </div>
        </div>
      </div>

      <hr class="cc-divider">

      {%- comment -%} Colors {%- endcomment -%}
      <div class="cc-filter-group">
        <div class="cc-filter-group-head">
          <h3>{{ sect.colors_heading | default: 'Colors' }}</h3>
        </div>
        <div class="cc-color-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'color_option' -%}
            <button type="button"
                    class="cc-color-swatch{% if block.settings.default_selected %} is-active{% endif %}"
                    style="--swatch-color: {{ block.settings.color }};"
                    data-cc-color-filter
                    data-value="{{ block.settings.tag_value }}"
                    aria-label="{{ block.settings.label }}"
                    title="{{ block.settings.label }}">
              <svg class="cc-check" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12l5 5L20 7" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <hr class="cc-divider">

      {%- comment -%} Sizes {%- endcomment -%}
      <div class="cc-filter-group">
        <div class="cc-filter-group-head">
          <h3>{{ sect.size_heading | default: 'Size' }}</h3>
        </div>
        <div class="cc-size-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'size_option' -%}
            <button type="button"
                    class="cc-size-pill{% if block.settings.default_selected %} is-active{% endif %}"
                    data-cc-size-filter
                    data-value="{{ block.settings.tag_value }}">
              {{ block.settings.label }}
            </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <hr class="cc-divider">

      {%- comment -%} Dress Style {%- endcomment -%}
      <div class="cc-filter-group">
        <div class="cc-filter-group-head">
          <h3>{{ sect.dress_style_heading | default: 'Dress Style' }}</h3>
        </div>
        <ul class="cc-style-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'style_option' -%}
            <li>
              <button type="button" class="cc-style-btn" data-cc-style-filter data-value="{{ block.settings.tag_value }}">
                <span>{{ block.settings.label }}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <button type="button" class="cc-apply-btn" data-cc-apply>{{ sect.apply_button_text | default: 'Apply Filter' }}</button>
    </aside>

    <div class="cc-main">
      <div class="cc-main-head">
        <h1 class="cc-page-title">{{ sect.page_title | default: collection_obj.title }}</h1>
        {%- if collection_obj -%}
        <div class="cc-sort-row">
          <span class="cc-results-count" data-cc-results-count>Showing 1-{{ per_page }} of {{ collection_obj.products_count }} Products</span>
          <label class="cc-sort">
            <span>{{ sect.sort_label | default: 'Sort by:' }}</span>
            <select name="sort_by" data-cc-sort>
              <option value="manual">{{ sect.sort_default_label | default: 'Most Popular' }}</option>
              <option value="price-ascending">Price: Low to High</option>
              <option value="price-descending">Price: High to Low</option>
              <option value="created-descending">Newest</option>
              <option value="title-ascending">Alphabetically, A-Z</option>
            </select>
          </label>
        </div>
        {%- endif -%}
      </div>

      {%- if collection_obj -%}
      {%- paginate collection_obj.products by per_page -%}
      <div class="cc-grid" data-cc-grid>
        {%- for product in collection_obj.products -%}
          {%- render 'casual-product-card', product: product -%}
        {%- else -%}
          <p class="cc-empty">{{ sect.empty_text | default: 'No products found in this collection yet.' }}</p>
        {%- endfor -%}
      </div>

      <p class="cc-no-results" data-cc-no-results hidden>{{ sect.no_results_text | default: 'No products match the selected filters.' }}</p>

      {%- if paginate.pages > 1 -%}
      <nav class="cc-pagination" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="cc-page-nav">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Previous
          </a>
        {%- else -%}
          <span class="cc-page-nav is-disabled">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Previous
          </span>
        {%- endif -%}

        <ul class="cc-page-numbers">
          {%- for part in paginate.parts -%}
            <li>
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="cc-page-num">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="cc-page-num is-current">{{ part.title }}</span>
              {%- else -%}
                <span class="cc-page-num is-ellipsis">{{ part.title }}</span>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="cc-page-nav">
            Next
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- else -%}
          <span class="cc-page-nav is-disabled">
            Next
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        {%- endif -%}
      </nav>
      {%- endif -%}
      {%- endpaginate -%}
      {%- else -%}
        <p class="cc-empty">Select a collection in the section settings to display products.</p>
      {%- endif -%}
    </div>
  </div>
</div>

<script src="{{ 'casual-collection.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Casual Collection Page",
  "settings": [
    { "type": "header", "content": "Collection & Content" },
    {
      "type": "paragraph",
      "content": "This section uses whatever collection the customer is currently viewing — add it to your Collection page template once and it works for every collection (Casual, Formal, Party, Gym, etc.). Only set an override below if you want this exact section instance to always show one specific collection."
    },
    { "type": "collection", "id": "collection_override", "label": "Override collection (optional)" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 3, "max": 24, "step": 1, "default": 9 },
    { "type": "text", "id": "page_title", "label": "Page title override (optional)", "info": "Leave blank to use the collection's own title." },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "text", "id": "breadcrumb_home_text", "label": "Breadcrumb home text", "default": "Home" },
    { "type": "url", "id": "breadcrumb_home_url", "label": "Breadcrumb home link" },
    { "type": "text", "id": "breadcrumb_current_text", "label": "Breadcrumb current text override (optional)", "info": "Leave blank to use the collection's own title." },
    { "type": "text", "id": "sort_label", "label": "Sort label", "default": "Sort by:" },
    { "type": "text", "id": "sort_default_label", "label": "Default sort option label", "default": "Most Popular" },
    { "type": "text", "id": "empty_text", "label": "Empty collection text", "default": "No products found in this collection yet." },
    { "type": "text", "id": "no_results_text", "label": "No filter results text", "default": "No products match the selected filters." },

    { "type": "header", "content": "Filters Panel Text" },
    { "type": "text", "id": "filters_heading", "label": "Filters heading", "default": "Filters" },
    { "type": "text", "id": "price_heading", "label": "Price heading", "default": "Price" },
    { "type": "text", "id": "colors_heading", "label": "Colors heading", "default": "Colors" },
    { "type": "text", "id": "size_heading", "label": "Size heading", "default": "Size" },
    { "type": "text", "id": "dress_style_heading", "label": "Dress Style heading", "default": "Dress Style" },
    { "type": "text", "id": "apply_button_text", "label": "Apply button text", "default": "Apply Filter" },

    { "type": "header", "content": "Price Range" },
    { "type": "range", "id": "price_floor", "label": "Slider minimum ($)", "min": 0, "max": 200, "step": 5, "default": 0 },
    { "type": "range", "id": "price_ceiling", "label": "Slider maximum ($)", "min": 100, "max": 1000, "step": 10, "default": 500 },
    { "type": "range", "id": "price_min_default", "label": "Default selected min ($)", "min": 0, "max": 500, "step": 5, "default": 50 },
    { "type": "range", "id": "price_max_default", "label": "Default selected max ($)", "min": 0, "max": 500, "step": 5, "default": 200 },

    { "type": "header", "content": "Typography" },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font family (Integra CF)",
      "options": [
        { "value": "'Integra CF', sans-serif", "label": "Integra CF" }
      ],
      "default": "'Integra CF', sans-serif"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "body_font",
      "label": "Body / description font (Satoshi)",
      "options": [
        { "value": "'Satoshi', sans-serif", "label": "Satoshi" }
      ],
      "default": "'Satoshi', sans-serif"
    },
    { "type": "range", "id": "page_title_size", "label": "Page title size (px)", "min": 18, "max": 56, "step": 1, "default": 32 },
    { "type": "range", "id": "product_title_size", "label": "Product card title size (px)", "min": 12, "max": 28, "step": 1, "default": 16 },
    { "type": "range", "id": "price_size", "label": "Price size (px)", "min": 12, "max": 28, "step": 1, "default": 16 },
    { "type": "range", "id": "body_size", "label": "Body / label text size (px)", "min": 10, "max": 22, "step": 1, "default": 14 },
    { "type": "color", "id": "accent_color", "label": "Accent color (buttons, sale badge)", "default": "#111111" }
  ],
  "blocks": [
    {
      "type": "type_option",
      "name": "Product type item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "T-shirts" },
        { "type": "text", "id": "tag_value", "label": "Matching product tag (e.g. type_tshirt)", "default": "type_tshirt" }
      ]
    },
    {
      "type": "color_option",
      "name": "Color swatch",
      "settings": [
        { "type": "text", "id": "label", "label": "Color name", "default": "Green" },
        { "type": "color", "id": "color", "label": "Swatch color", "default": "#3DB54A" },
        { "type": "text", "id": "tag_value", "label": "Matching product tag (e.g. color_green)", "default": "color_green" },
        { "type": "checkbox", "id": "default_selected", "label": "Selected by default", "default": false }
      ]
    },
    {
      "type": "size_option",
      "name": "Size option",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Medium" },
        { "type": "text", "id": "tag_value", "label": "Matching product tag (e.g. size_medium)", "default": "size_medium" },
        { "type": "checkbox", "id": "default_selected", "label": "Selected by default", "default": false }
      ]
    },
    {
      "type": "style_option",
      "name": "Dress style item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Casual" },
        { "type": "text", "id": "tag_value", "label": "Matching product tag (e.g. style_casual)", "default": "style_casual" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Casual Collection Page",
      "blocks": [
        { "type": "type_option", "settings": { "label": "T-shirts", "tag_value": "type_tshirt" } },
        { "type": "type_option", "settings": { "label": "Shorts", "tag_value": "type_shorts" } },
        { "type": "type_option", "settings": { "label": "Shirts", "tag_value": "type_shirts" } },
        { "type": "type_option", "settings": { "label": "Hoodie", "tag_value": "type_hoodie" } },
        { "type": "type_option", "settings": { "label": "Jeans", "tag_value": "type_jeans" } },

        { "type": "color_option", "settings": { "label": "Green", "color": "#3DB54A", "tag_value": "color_green" } },
        { "type": "color_option", "settings": { "label": "Red", "color": "#EE2C2C", "tag_value": "color_red" } },
        { "type": "color_option", "settings": { "label": "Yellow", "color": "#F5CB35", "tag_value": "color_yellow" } },
        { "type": "color_option", "settings": { "label": "Orange", "color": "#F98A34", "tag_value": "color_orange" } },
        { "type": "color_option", "settings": { "label": "Cyan", "color": "#3FCBE5", "tag_value": "color_cyan" } },
        { "type": "color_option", "settings": { "label": "Blue", "color": "#2151D1", "tag_value": "color_blue" } },
        { "type": "color_option", "settings": { "label": "Purple", "color": "#7443C4", "tag_value": "color_purple" } },
        { "type": "color_option", "settings": { "label": "Pink", "color": "#E8398C", "tag_value": "color_pink" } },
        { "type": "color_option", "settings": { "label": "White", "color": "#FFFFFF", "tag_value": "color_white" } },
        { "type": "color_option", "settings": { "label": "Black", "color": "#111111", "tag_value": "color_black" } },

        { "type": "size_option", "settings": { "label": "XX-Small", "tag_value": "size_xxsmall" } },
        { "type": "size_option", "settings": { "label": "X-Small", "tag_value": "size_xsmall" } },
        { "type": "size_option", "settings": { "label": "Small", "tag_value": "size_small" } },
        { "type": "size_option", "settings": { "label": "Medium", "tag_value": "size_medium" } },
        { "type": "size_option", "settings": { "label": "Large", "tag_value": "size_large" } },
        { "type": "size_option", "settings": { "label": "X-Large", "tag_value": "size_xlarge" } },
        { "type": "size_option", "settings": { "label": "XX-Large", "tag_value": "size_xxlarge" } },
        { "type": "size_option", "settings": { "label": "3X-Large", "tag_value": "size_3xlarge" } },
        { "type": "size_option", "settings": { "label": "4X-Large", "tag_value": "size_4xlarge" } },

        { "type": "style_option", "settings": { "label": "Casual", "tag_value": "style_casual" } },
        { "type": "style_option", "settings": { "label": "Formal", "tag_value": "style_formal" } },
        { "type": "style_option", "settings": { "label": "Party", "tag_value": "style_party" } },
        { "type": "style_option", "settings": { "label": "Gym", "tag_value": "style_gym" } }
      ]
    }
  ]
}
{% endschema %}

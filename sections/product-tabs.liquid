{% comment %}
  Section: Product Tabs (Product Details / Rating & Reviews / FAQs)
  - Add exactly 3 "Tab label" blocks to control the tab button text.
    Their order sets the button order, but content panels are wired to
    fixed positions: 1st = Product Details, 2nd = Reviews, 3rd = FAQs.
  - Add repeatable "Review" blocks and "FAQ" blocks to populate those
    two panels — reorder/add/remove them freely in the customizer.
{% endcomment %}

{{ 'custom-product-page.css' | asset_url | stylesheet_tag }}

<style>
  @font-face {
    font-family: 'Integra CF';
    src: url('{{ "IntegraCF-Medium.woff2" | asset_url }}') format('woff2');
    font-weight: 500;
    font-display: swap;
  }
  @font-face {
    font-family: 'Integra CF';
    src: url('{{ "IntegraCF-Bold.woff2" | asset_url }}') format('woff2');
    font-weight: 700;
    font-display: swap;
  }
  @font-face {
    font-family: 'Satoshi';
    src: url('{{ "Satoshi-Regular.woff2" | asset_url }}') format('woff2');
    font-weight: 400;
    font-display: swap;
  }
  @font-face {
    font-family: 'Satoshi';
    src: url('{{ "Satoshi-Medium.woff2" | asset_url }}') format('woff2');
    font-weight: 500;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --cpp-heading-font: 'Integra CF', 'Helvetica Neue', Arial, sans-serif;
    --cpp-heading-weight: {{ section.settings.heading_font_weight }};
    --cpp-body-font: 'Satoshi', -apple-system, BlinkMacSystemFont, sans-serif;
    --cpp-desc-size: {{ section.settings.description_font_size }}px;
    --cpp-subheading-size: {{ section.settings.subheading_font_size }}px;
    --cpp-section-heading-size: {{ section.settings.section_heading_size }}px;
    --cpp-review-text-size: {{ section.settings.review_text_font_size }}px;
    --cpp-accent: {{ section.settings.accent_color }};
    --cpp-text: {{ section.settings.text_color }};
    --cpp-muted: {{ section.settings.muted_color }};
    --cpp-border: {{ section.settings.border_color }};
    background: {{ section.settings.background_color }};
    font-family: var(--cpp-body-font);
    color: var(--cpp-text);
  }
</style>

<div class="cpp-wrapper" id="shopify-section-{{ section.id }}">
  <div class="cpp-tabs-wrapper">
    <div class="cpp-tabs-nav" role="tablist">
      {% for block in section.blocks %}
        {% if block.type == 'tab_label' %}
          <button
            type="button"
            class="cpp-tab-btn{% if forloop.first %} is-active{% endif %}"
            role="tab"
            data-cpp-tab-btn
            data-target="cpp-panel-{{ forloop.index }}-{{ section.id }}"
          >{{ block.settings.label }}</button>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Panel 1: Product Details -->
    <div class="cpp-tab-panel is-active" id="cpp-panel-1-{{ section.id }}" data-cpp-panel>
      {% for block in section.blocks %}
        {% if block.type == 'product_detail' %}
          <div class="cpp-rich-text">{{ block.settings.content }}</div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Panel 2: Rating & Reviews -->
    <div class="cpp-tab-panel" id="cpp-panel-2-{{ section.id }}" data-cpp-panel hidden>
      {% assign review_blocks = section.blocks | where: 'type', 'review' %}
      <div class="cpp-reviews-header">
        <h2 class="cpp-section-heading">All Reviews <span class="cpp-muted">({{ section.settings.review_count | default: review_blocks.size }})</span></h2>
        <div class="cpp-reviews-controls">
          <button type="button" class="cpp-icon-btn" aria-label="Filter reviews">⚙︎</button>
          <select class="cpp-sort-select" aria-label="Sort reviews">
            <option>Latest</option>
            <option>Oldest</option>
            <option>Highest Rated</option>
            <option>Lowest Rated</option>
          </select>
          <button type="button" class="cpp-write-review-btn">Write a Review</button>
        </div>
      </div>

      <div class="cpp-reviews-grid">
        {% for block in review_blocks %}
          <div class="cpp-review-card" {{ block.shopify_attributes }}>
            <div class="cpp-review-top">
              <span class="cpp-review-stars" aria-hidden="true">
                {% for i in (1..5) %}{% if i <= block.settings.rating %}★{% else %}☆{% endif %}{% endfor %}
              </span>
              <button type="button" class="cpp-review-more" aria-label="More options">•••</button>
            </div>
            <p class="cpp-review-name">
              {{ block.settings.reviewer_name }}
              {% if block.settings.verified %}<span class="cpp-verified" title="Verified buyer">✓</span>{% endif %}
            </p>
            <p class="cpp-review-text">&ldquo;{{ block.settings.review_text }}&rdquo;</p>
            <p class="cpp-review-date">Posted on {{ block.settings.review_date }}</p>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_load_more %}
        <div class="cpp-load-more-row">
          <button type="button" class="cpp-load-more-btn">Load More Reviews</button>
        </div>
      {% endif %}
    </div>

    <!-- Panel 3: FAQs -->
    <div class="cpp-tab-panel" id="cpp-panel-3-{{ section.id }}" data-cpp-panel hidden>
      {% assign faq_blocks = section.blocks | where: 'type', 'faq' %}
      <div class="cpp-faq-list">
        {% for block in faq_blocks %}
          <div class="cpp-faq-item" {{ block.shopify_attributes }}>
            <button type="button" class="cpp-faq-question" data-cpp-faq-toggle>
              <span>{{ block.settings.question }}</span>
              <span class="cpp-faq-icon">+</span>
            </button>
            <div class="cpp-faq-answer">
              <p>{{ block.settings.answer }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    // Tabs
    var tabBtns = root.querySelectorAll('[data-cpp-tab-btn]');
    var panels = root.querySelectorAll('[data-cpp-panel]');
    tabBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        tabBtns.forEach(function (b) { b.classList.remove('is-active'); });
        panels.forEach(function (p) {
          p.classList.remove('is-active');
          p.hidden = true;
        });
        btn.classList.add('is-active');
        var target = document.getElementById(btn.getAttribute('data-target'));
        if (target) {
          target.hidden = false;
          target.classList.add('is-active');
        }
      });
    });

    // FAQ accordion
    root.querySelectorAll('[data-cpp-faq-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.closest('.cpp-faq-item');
        item.classList.toggle('is-open');
      });
    });
  })();
</script>

{% schema %}
{

{{ 'customer-reviews.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --cr-section-bg: {{ section.settings.section_background }};
    --cr-card-bg: {{ section.settings.card_background }};
    --cr-card-border: {{ section.settings.card_border_color }};
    --cr-heading-color: {{ section.settings.heading_color }};
    --cr-name-color: {{ section.settings.name_color }};
    --cr-text-color: {{ section.settings.review_text_color }};
    --cr-star-color: {{ section.settings.star_color }};
    --cr-arrow-color: {{ section.settings.arrow_color }};
    --cr-arrow-bg: {{ section.settings.arrow_background }};
    --cr-verified-color: {{ section.settings.verified_badge_color }};
    --cr-cards-desktop: {{ section.settings.cards_per_view_desktop }};
    --cr-cards-tablet: {{ section.settings.cards_per_view_tablet }};
  }

  {%- if section.settings.font_medium_url != blank -%}
    @font-face {
      font-family: 'Integra CF';
      src: url('{{ section.settings.font_medium_url }}') format('woff2');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
  {%- endif -%}
  {%- if section.settings.font_bold_url != blank -%}
    @font-face {
      font-family: 'Integra CF';
      src: url('{{ section.settings.font_bold_url }}') format('woff2');
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .cr-font {
    font-family: {% if section.settings.font_medium_url != blank or section.settings.font_bold_url != blank %}'Integra CF',{% endif %} {{ section.settings.fallback_font }};
  }
  #shopify-section-{{ section.id }} .cr-review-text {
    font-family: 'Satoshi Variable', sans-serif;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .cr-heading {
      font-size: {{ section.settings.heading_size_mobile }}px !important;
    }
  }
{%- endstyle -%}

<div class="cr-wrapper" style="background-color: var(--cr-section-bg);" id="cr-{{ section.id }}">
  <div class="cr-inner">
    <div class="cr-top-row">
      {%- if section.settings.heading != blank -%}
        <h2
          class="cr-font cr-heading"
          style="
            color: var(--cr-heading-color);
            font-size: {{ section.settings.heading_size_desktop }}px;
            font-weight: {{ section.settings.heading_font_weight }};
          "
        >
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <div class="cr-nav-arrows">
        <button type="button" class="cr-arrow cr-arrow-prev" aria-label="Previous reviews">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button type="button" class="cr-arrow cr-arrow-next" aria-label="Next reviews">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <div class="cr-track" tabindex="0">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="cr-card" style="background-color: var(--cr-card-bg); border-color: var(--cr-card-border);" {{ block.shopify_attributes }}>
            <div class="cr-stars" aria-hidden="true">
              {%- assign full_stars = block.settings.rating | floor -%}
              {%- assign empty_stars = 5 | minus: full_stars -%}
              {%- for i in (1..full_stars) -%}★{%- endfor -%}
              {%- for i in (1..empty_stars) -%}☆{%- endfor -%}
            </div>

            <div class="cr-name-row">
              <span class="cr-font cr-name" style="color: var(--cr-name-color);">{{ block.settings.name }}</span>
              {%- if block.settings.verified -%}
                <span class="cr-verified" title="Verified Buyer">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--cr-verified-color)"><path d="M12 2l2.4 2.2 3.2-.6.9 3.1 3.1.9-.6 3.2L23 12l-2.2 2.4.6 3.2-3.1.9-.9 3.1-3.2-.6L12 23l-2.4-2.2-3.2.6-.9-3.1-3.1-.9.6-3.2L1 12l2.2-2.4-.6-3.2 3.1-.9.9-3.1 3.2.6L12 2z"/><path d="M9 12.5l2 2 4-4.5" stroke="#fff" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              {%- endif -%}
            </div>

            <p class="cr-font cr-review-text" style="color: var(--cr-text-color);">
              &ldquo;{{ block.settings.review_text }}&rdquo;
            </p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var wrapper = document.getElementById('cr-{{ section.id }}');
    if (!wrapper) return;

    function init() {
      var track = wrapper.querySelector('.cr-track');
      var prevBtn = wrapper.querySelector('.cr-arrow-prev');
      var nextBtn = wrapper.querySelector('.cr-arrow-next');
      if (!track || track.dataset.crInit) return;
      track.dataset.crInit = 'true';

      function scrollAmount() {
        var card = track.querySelector('.cr-card');
        if (!card) return 0;
        var style = getComputedStyle(track);
        var gap = parseFloat(style.columnGap || style.gap || 0);
        return card.getBoundingClientRect().width + gap;
      }

      prevBtn.addEventListener('click', function () {
        track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
      });
      nextBtn.addEventListener('click', function () {
        track.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('shopify:section:load', init);
  })();
</script>

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "section-customer-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR HAPPY CUSTOMERS"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading weight",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size — desktop (px)",
      "min": 18,
      "max": 60,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size — mobile (px)",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 24
    },
    {
      "type": "header",
      "content": "Carousel layout"
    },
    {
      "type": "range",
      "id": "cards_per_view_desktop",
      "label": "Cards visible — desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "cards_per_view_tablet",
      "label": "Cards visible — tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Custom font (Integra CF)"
    },
    {
      "type": "url",
      "id": "font_medium_url",
      "label": "Integra CF Medium file URL (.woff2)"
    },
    {
      "type": "url",
      "id": "font_bold_url",
      "label": "Integra CF Bold file URL (.woff2)"
    },
    {
      "type": "text",
      "id": "fallback_font",
      "label": "Fallback font stack",
      "default": "Helvetica Neue, Arial, sans-serif"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#e8e6e1"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Reviewer name color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "review_text_color",
      "label": "Review text color",
      "default": "#4b4b4b"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#ffc633"
    },
    {
      "type": "color",
      "id": "verified_badge_color",
      "label": "Verified badge color",
      "default": "#2fb344"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow icon color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow button background",
      "default": "#f2f0f1"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Sarah M."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show \"verified\" badge",
          "default": true
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "I'm blown away by the quality and style of the clothes I received. Every piece exceeded my expectations."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
